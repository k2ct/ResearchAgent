# ===================================================================
# ResearchAgent v0.5 — 环境变量模板
# ===================================================================
# 使用方式：
#   1. 复制此文件为 .env ：  copy .env.example .env
#   2. 根据你的需求修改 .env 中的配置
#   3. 如果不使用 LLM / MinerU 等高级功能，保持默认值即可
#   4. ⚠️ .env 已加入 .gitignore，绝对不要提交到 Git
# ===================================================================

# =========================
# A. LLM API 配置（可选）
# =========================
# ResearchAgent 兼容 OpenAI SDK 风格的 API，可以使用 OpenAI / DeepSeek
# 或其他兼容服务。
# - 如果不填 API Key，所有 LLM 相关功能将不可用（不会报错，自动 fallback 规则版）
# - 默认模型建议使用 gpt-4o-mini 或 deepseek-v4-pro
# - 不要将真实 API Key 写在此文件中，只写在 .env
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# 是否使用 LLM 进行任务分类（默认 false，使用规则版分类器）
USE_LLM_CLASSIFIER=false

# =========================
# B. LLM Enhancement 增强开关（可选）
# =========================
# 控制是否使用 LLM 对以下模块的输出进行增强润色：
#   - Claim Support（声明支撑检索）
#   - Paper Reading（论文阅读笔记）
#   - PPT Progress Memory（组会进展追踪）
#   - Report Polish（汇报文本润色）
# - false（默认）：所有模块使用纯规则版逻辑，无需 LLM
# - true：规则版输出会交由 LLM 增强，受证据约束，不虚构内容
# - LLM API 不可用时自动 fallback 规则版，不影响主流程
ENABLE_LLM_ENHANCEMENT=false
# 是否使用 LLM 生成汇报（Report Writer 的 LLM 模式）
# - false（默认）：使用模板版 Report Writer
# - true：使用 LLM 生成自然语言汇报，并自动检测汇报风格（组会/PPT/论文摘要）
ENABLE_LLM_REPORT_WRITER=false
# LLM 温度参数：0.0 = 确定性输出，0.5 = 较有创意，推荐 0.2
LLM_TEMPERATURE=0.2
# LLM 最大输入字符数（超过此长度的内容会被截断再发送给 LLM）
LLM_MAX_INPUT_CHARS=12000

# =========================
# C. RAG 检索配置
# =========================
# 检索模式：
#   vector（默认）：纯 Chroma 向量相似度检索
#   hybrid：向量检索 + 关键词检索 + 分数融合
RAG_RETRIEVAL_MODE=vector
# 文档分块参数（影响索引构建时的切片行为）
# 单个 chunk 最大字符数（默认 1200）
RAG_CHUNK_MAX_CHARS=1200
# 相邻段落合并的最小字符阈值（默认 250）
RAG_CHUNK_MIN_CHARS=250
# 段落切分时的重叠字符数（默认 150）
RAG_CHUNK_OVERLAP_CHARS=150

# =========================
# D. Memory 记忆系统配置（可选）
# =========================
# 控制主 Agent 是否在推理时检索历史记忆
# - false（默认）：不检索记忆，单次查询独立运行
# - true：主 Agent 会从 data/memory/ 检索相关记忆并注入回答上下文
# 记忆数据保存在 data/memory/*.jsonl 和 *.md 文件中（不提交 Git）
ENABLE_MEMORY_AWARE_AGENT=false
# 每次查询最多检索的记忆记录数（默认 5）
MEMORY_TOP_K=5
# 是否在检索时包含短期记忆（默认 true）
MEMORY_INCLUDE_SHORT_TERM=true
# 是否在检索时包含已过期的记忆（默认 false）
MEMORY_INCLUDE_EXPIRED=false

# =========================
# E. Multi-Agent 多智能体配置（可选）
# =========================
# 控制是否启用 9-Agent 协作架构
# - false（默认）：使用单 Agent 模式，不引入额外开销
# - true：启用 orchestrator / handoff / executors / tracing / arbitration
#   根据任务类型分发给 9 个 Specialist Agent 执行
ENABLE_MULTI_AGENT=false

# =========================
# F. 文档摄入后端配置
# =========================
# 文档摄入后端选择：
#   local（默认）：使用 pymupdf / python-docx / python-pptx 本地解析，无需 API Key
#   mineru：调用 MinerU API 解析复杂 PDF（公式/表格/OCR），需要 MINERU_API_KEY
# MinerU 调用失败时自动 fallback 到 local backend，不会中断批量摄入
DOCUMENT_INGESTION_BACKEND=local

# =========================
# G. MinerU API 配置（仅 DOCUMENT_INGESTION_BACKEND=mineru 时需要）
# =========================
# MinerU 用于解析包含复杂公式、表格、OCR 内容的 PDF
# 不填 Key 时 MinerU 不会启用
MINERU_API_KEY=your_mineru_api_key_here
# MinerU API 基础地址（仅主机名，如 https://mineru.net）
MINERU_API_BASE_URL=https://mineru.net
# API 模式：
#   precise：官方 MinerU v4 高精度解析 API（适合复杂文档）
#   agent：官方 MinerU Agent 轻量解析 API（适合简单文档）
#   local_fastapi：自部署 MinerU API
MINERU_API_MODE=precise
# 高精度模式下的模型版本：vlm | pipeline | MinerU-HTML
MINERU_MODEL_VERSION=vlm
# 各 API 端点（通常使用默认值即可，自部署时按需修改）
MINERU_PARSE_ENDPOINT=https://mineru.net/api/v4/extract/task
MINERU_FILE_URLS_ENDPOINT=https://mineru.net/api/v4/file-urls/batch
MINERU_BATCH_RESULTS_ENDPOINT=https://mineru.net/api/v4/extract-results/batch/{batch_id}
MINERU_TASK_STATUS_ENDPOINT=https://mineru.net/api/v4/extract/task/{task_id}
MINERU_RESULT_ENDPOINT=
# 异步解析轮询间隔（秒），默认 3
MINERU_POLL_INTERVAL_SECONDS=3
# 单个文档最大等待时间（秒），默认 300
MINERU_MAX_WAIT_SECONDS=300
# 代理设置：Windows 上如果遇到 SOCKS proxy / socksio 问题，可设 MINERU_DISABLE_PROXY=true 绕过系统代理
# 或安装 SOCKS 支持：pip install "httpx[socks]" socksio
MINERU_DISABLE_PROXY=false
MINERU_HTTP_PROXY=
MINERU_HTTPS_PROXY=

# =========================
# H. HuggingFace 离线配置
# =========================
# 如果 HuggingFace 网络不稳定，且 embedding 模型已经缓存到本地，建议设置为 1。
# 这可以避免 Windows 下 WinError 10054 / 代理中断 / socksio / httpx 等问题。
# - 不设置（默认）：首次构建索引时会从 HuggingFace Hub 下载 embedding model
# - 设为 1：跳过联网下载，要求模型已缓存到本地
#   适用于：网络不稳定、离线环境、或已成功运行过一次 build_index 的场景
HF_HUB_OFFLINE=1

# =========================
# I. Streamlit 运行说明（不在 .env 中配置，仅作参考）
# =========================
# Streamlit 的端口和 watcher 配置通过 .streamlit/config.toml 或命令行参数控制：
#   streamlit run app.py --server.port 8503
#   streamlit run app.py --server.port 8504 --server.fileWatcherType none
# Windows 用户如果遇到 torch/torchvision 相关 watcher 报错，建议加
# --server.fileWatcherType none，不需要额外安装 torchvision
