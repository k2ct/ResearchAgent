# =========================
# LLM API Configuration
# =========================
# OpenAI-compatible API key and endpoint
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Enable LLM-based task classifier (default: false)
USE_LLM_CLASSIFIER=false

# Enable LLM-assisted report writer (default: false)
ENABLE_LLM_REPORT_WRITER=false

# =========================
# Optional LLM Enhancement
# =========================
# Master switch for LLM-enhanced outputs across all research modules
# (claim support, paper reading, PPT progress memory, report polish).
# When false (default), all modules use rule-based output.
ENABLE_LLM_ENHANCEMENT=false
# LLM temperature for enhancement tasks (0.0 = deterministic, 0.5 = creative)
LLM_TEMPERATURE=0.2
# Maximum input characters sent to LLM (longer content is truncated)
LLM_MAX_INPUT_CHARS=12000

# =========================
# Memory-aware Agent
# =========================
# Enable memory-aware retrieval in the main agent flow.
# When true, the agent retrieves relevant research memories alongside
# RAG documents and merges them into the final answer context.
ENABLE_MEMORY_AWARE_AGENT=false
# Maximum memory records to retrieve per query (default: 5)
MEMORY_TOP_K=5
# Include short-term memories in retrieval (default: true)
MEMORY_INCLUDE_SHORT_TERM=true
# Include expired memories in retrieval (default: false)
MEMORY_INCLUDE_EXPIRED=false

# =========================
# RAG Retrieval Mode
# =========================
# vector: Chroma vector similarity search only (default)
# hybrid: vector search + keyword search + score fusion
RAG_RETRIEVAL_MODE=vector

# =========================
# Optional MinerU Document Parsing
# =========================
# local: use built-in text extractors (default, no API key needed)
# mineru: use MinerU API for complex PDFs, formulas, tables, OCR
DOCUMENT_INGESTION_BACKEND=local
# your MinerU API key (only needed when backend=mineru)
MINERU_API_KEY=your_mineru_api_key_here
# MinerU API base URL (host only, e.g. https://mineru.net)
MINERU_API_BASE_URL=https://mineru.net
# API mode: precise | agent | local_fastapi
#   precise: official MinerU v4 precise parsing API
#   agent: official MinerU Agent lightweight parsing API
#   local_fastapi: self-hosted MinerU API
MINERU_API_MODE=precise
# Model version for precise mode: vlm | pipeline | MinerU-HTML
MINERU_MODEL_VERSION=vlm
# URL task endpoint (for remote file URLs, not local uploads)
MINERU_PARSE_ENDPOINT=https://mineru.net/api/v4/extract/task
# Local file upload batch endpoint
MINERU_FILE_URLS_ENDPOINT=https://mineru.net/api/v4/file-urls/batch
# Batch results endpoint (use {batch_id} placeholder)
MINERU_BATCH_RESULTS_ENDPOINT=https://mineru.net/api/v4/extract-results/batch/{batch_id}
# Single task status endpoint (use {task_id} placeholder)
MINERU_TASK_STATUS_ENDPOINT=https://mineru.net/api/v4/extract/task/{task_id}
MINERU_RESULT_ENDPOINT=
# seconds between poll checks for async parsing
MINERU_POLL_INTERVAL_SECONDS=3
# maximum seconds to wait for a single document
MINERU_MAX_WAIT_SECONDS=300
# Proxy: set to true to bypass system proxy
MINERU_DISABLE_PROXY=false
MINERU_HTTP_PROXY=
MINERU_HTTPS_PROXY=

# =========================
# RAG Chunking Configuration
# =========================
# Maximum characters per chunk (default: 1200)
RAG_CHUNK_MAX_CHARS=1200
# Minimum characters before merging adjacent sections (default: 250)
RAG_CHUNK_MIN_CHARS=250
# Overlap characters between paragraph-split chunks (default: 150)
RAG_CHUNK_OVERLAP_CHARS=150
