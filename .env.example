# =========================
# LLM API Configuration
# =========================
# OpenAI-compatible API key and endpoint
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Enable LLM-based task classifier (default: false)
USE_LLM_CLASSIFIER=false

# Enable LLM-assisted report writer (default: false)
ENABLE_LLM_REPORT_WRITER=false

# =========================
# RAG Retrieval Mode
# =========================
# vector: Chroma vector similarity search only (default)
# hybrid: vector search + keyword search + score fusion
RAG_RETRIEVAL_MODE=vector
